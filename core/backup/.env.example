# OpenClaw Backup — Environment Variables
# Copy to .env and fill in values

# ── Encryption ─────────────────────────────────────────────────────────────────
# Strong password for AES-256 archive encryption
BACKUP_PASSWORD=your-strong-password-here

# ── Google Drive OAuth2 ────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GDRIVE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GDRIVE_CLIENT_SECRET=GOCSPX-your-client-secret

# Generated by: node auth-setup.js
GDRIVE_REFRESH_TOKEN=1//your-refresh-token

# ── Telegram (optional override) ───────────────────────────────────────────────
# If not set, reads botToken from ~/.openclaw/clawdbot.json automatically
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=455103738
